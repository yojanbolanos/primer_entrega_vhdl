library ieee; 
 use library.std_logic_1164.all;
 
entity fiveb is


	port
	(
		-- Input ports
		entrada	: in  std_logic_vector(3 downto 0) ;
		
		-- Output ports
		seg	: out std_logic_vector(6 downto 0)
		
	);
end fiveb ;


-- Library Clause(s) (optional)
-- Use Clause(s) (optional)

architecture arch_fiveb of fiveb is


begin

 with entrada select
 --          abcdefg
	seg <=   "0000001" when "0000",
				"1001111" when "0001",
				"0010010" when "0010",
				"0000110" when "0011",
				"1001100" when "0100",
				"0100100" when "0101",
				"0100000" when "0110",
				"0001111" when "0111",
				"0000000" when "1000",
				"0000100" when "1001",
				"1111110" when others;

end arch_fiveb;

